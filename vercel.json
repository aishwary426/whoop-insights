{
    "rewrites": [
        {
            "source": "/api/v1/:path*",
            "destination": "/api/index.py"
        }
    ],
    "functions": {
        "api/index.py": {
            "runtime": "python3.11",
            "maxDuration": 300,
            "memory": 1024,
            "includeFiles": "backend/**"
        }
    }
}